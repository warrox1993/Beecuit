# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Auth.js v5 ────────────────────────────────────────────────
AUTH_SECRET="run: openssl rand -base64 33"
AUTH_URL="http://localhost:3000"

# ── Resend (transactional emails) ─────────────────────────────
AUTH_RESEND_KEY="re_..."
AUTH_EMAIL_FROM="BeeCuit <onboarding@resend.dev>"

# ── Google OAuth (set both for production) ───────────────────
AUTH_GOOGLE_ID="" # from https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_SECRET=""

# ── Public app config ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_TAX_RATE_ID="txr_..."

# ── Vercel Blob ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Journal (HMAC for preview tokens) ─────────────────────────
JOURNAL_PREVIEW_SECRET="replace-me-with-32-plus-char-random-string"
